# Claude API
ANTHROPIC_API_KEY=

# URL pública del backend (la que los providers van a usar como redirect URI).
# En dev poné http://<IP-LAN>:3000 para que el celular llegue al server.
PUBLIC_BACKEND_URL=http://localhost:3000

# Scheme de la app móvil — debe coincidir con app.json "scheme"
# El backend redirige al final del OAuth a glosx://auth/<provider>?...
APP_SCHEME=glosx

# === Twitter / X ===
# https://developer.x.com → Project → User authentication settings
# Type: Confidential client (PKCE), Callback URL: $PUBLIC_BACKEND_URL/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# === Reddit ===
# https://www.reddit.com/prefs/apps  (type: web app)
# Redirect URI: $PUBLIC_BACKEND_URL/auth/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=glosx/1.0 by yourusername

# === LinkedIn ===
# https://www.linkedin.com/developers/apps
# Redirect URI: $PUBLIC_BACKEND_URL/auth/linkedin/callback
# Products requeridos: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# === Pinterest ===
# https://developers.pinterest.com/apps
# Redirect URI: $PUBLIC_BACKEND_URL/auth/pinterest/callback
# Scopes: pins:write, boards:read
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# === TikTok ===
# https://developers.tiktok.com/apps
# Redirect URI: $PUBLIC_BACKEND_URL/auth/tiktok/callback
# Scopes: user.info.basic, video.publish (Content Posting API requiere aprobación manual)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# === Facebook (Pages) ===
# https://developers.facebook.com/apps
# Redirect URI: $PUBLIC_BACKEND_URL/auth/facebook/callback
# Scopes: pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
